# ============================================
# Page Studio — Server Environment Variables
# ============================================

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/page-studio

# Server port
PORT=8000

# JWT Secret — CHANGE THIS IN PRODUCTION
JWT_SECRET=your-jwt-secret-key-change-me-in-production
JWT_EXPIRES_IN=15m

JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-change-me-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Admin Secret Key — Used to create/manage users via X-Admin-Key header
ADMIN_SECRET_KEY=your-admin-secret-key-change-me

# Frontend URL (for CORS setup)
FRONTEND_URL=http://localhost:3000
